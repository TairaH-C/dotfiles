# Navigation
alias ll='ls -lAh --color=auto'
alias ..='cd ..'
alias ...='cd ../..'

# Modern CLI replacements
alias vi='nvim'
alias vim='nvim'
alias cat='bat --paging=never'
alias grep='rg'
alias find='fd'

# Git shortcuts
alias gs='git status'
alias gd='git diff'
alias gl='git log --oneline -20'
alias lg='lazygit'

# Safety
alias rm='rm -i'
alias mv='mv -i'
alias cp='cp -i'
