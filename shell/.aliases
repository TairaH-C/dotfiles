# -- Navigation ----------------------------------------------------------------

alias ..='cd ..'
alias ...='cd ../..'
alias ....='cd ../../..'

# -- Modern CLI replacements ---------------------------------------------------

# ls -> eza (drop-in compatible)
if command -v eza &>/dev/null; then
  alias ls='eza --icons'
  alias ll='eza -lah --icons --git'
  alias lt='eza --tree --icons --level=2 --git-ignore'
  alias la='eza -a --icons'
else
  alias ll='ls -lAh --color=auto'
fi

# cat -> bat (auto-detects TTY; safe in pipes)
if command -v bat &>/dev/null; then
  alias cat='bat --paging=never'
fi

# NOTE: grep / find / cd are NOT aliased intentionally.
# Overriding them breaks scripts and muscle memory (different flags).
# Use `rg` / `fd` / `z` directly — they are in PATH.

# -- Editors -------------------------------------------------------------------

alias vi='nvim'
alias vim='nvim'

# -- Git shortcuts -------------------------------------------------------------

alias gs='git status'
alias gd='git diff'
alias gl='git log --oneline -20'
alias glo='git log --graph --oneline --decorate -20'
alias lg='lazygit'

# -- AI tools ------------------------------------------------------------------

alias oc='opencode'

# -- Safety --------------------------------------------------------------------

alias rm='rm -i'
alias mv='mv -i'
alias cp='cp -i'
