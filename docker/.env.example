# Copy to docker/.env and fill in. docker/.env is gitignored.
#
#   cp docker/.env.example docker/.env

# Required for Claude Code (CLI auth uses this if no interactive login).
ANTHROPIC_API_KEY=

# Optional. Only needed if you use OpenAI-backed tools.
OPENAI_API_KEY=

# Optional. Personal access token for private repo / gh CLI flows.
GITHUB_TOKEN=

# Optional. Bind-mount root for `~/workspace`. Defaults to ~/workspace
# in docker/docker-compose.yml. Override here if your code lives elsewhere.
# WORKSPACE_ROOT=/abs/path/to/code

# Optional. Path to your personal gitconfig fragment (user.email etc.).
# Defaults to ./persist/.gitconfig.local in docker/docker-compose.yml.
# GITCONFIG_LOCAL=./persist/.gitconfig.local
