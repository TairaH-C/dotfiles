{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "language": "japanese",
  "enabledMcpjsonServers": ["drawio"],
  "permissions": {
    "allow": [
      "Bash(uv run ruff check *)",
      "Bash(uv run ruff format *)",
      "Bash(uv run pytest *)",
      "Bash(uv sync *)",
      "Bash(pf flow validate *)",
      "Bash(git status)",
      "Bash(git log *)",
      "Bash(git diff *)",
      "Bash(git add *)",
      "Bash(git commit *)",
      "Bash(git branch *)",
      "Bash(git checkout *)",
      "Bash(git switch *)",
      "Bash(cd *)"
    ],
    "deny": [
      "Read(./.env)",
      "Read(./.env.*)",
      "Read(./secrets.json)",
      "Read(./prompts/config/**)",
      "Bash(git push --force *)",
      "Bash(git reset --hard *)"
    ]
  }
}
