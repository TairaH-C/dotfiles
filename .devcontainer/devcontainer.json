{
  "name": "dev-environment",
  "build": {
    "dockerfile": "../docker/Dockerfile",
    "context": "../"
  },
  "mounts": [
    "source=${localEnv:HOME}/.ssh,target=/home/dev/.ssh,type=bind,readonly",
    "source=${localEnv:HOME}/.config/github-copilot,target=/home/dev/.config/github-copilot,type=bind,readonly",
    "source=${localEnv:HOME}/workspace,target=/home/dev/workspace,type=bind",
    "source=devenv-claude-state,target=/home/dev/.claude,type=volume"
  ],
  "remoteUser": "dev",
  "postCreateCommand": "bash /home/dev/workspace/dotfiles/install.sh --docker",
  "containerEnv": {
    "TERM": "xterm-256color"
  },
  "customizations": {
    "vscode": {
      "settings": {
        "python.defaultInterpreterPath": ".venv/bin/python",
        "editor.formatOnSave": true,
        "[python]": {
          "editor.defaultFormatter": "charliermarsh.ruff"
        }
      },
      "extensions": [
        "ms-python.python",
        "ms-python.vscode-pylance",
        "charliermarsh.ruff",
        "tamasfe.even-better-toml",
        "mhutchie.git-graph"
      ]
    }
  },
  "forwardPorts": []
}
